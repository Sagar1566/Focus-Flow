<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- ===== MAIN CONTENT ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomNavContainer"
        android:scrollbars="none"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="32dp">

                <TextView
                    android:id="@+id/tvPlannerTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Planer"
                    android:textColor="#000000"
                    android:textSize="48sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_planner_logo"
                    android:tint="#121417" />
            </RelativeLayout>

            <!-- Today's Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/task_badge_bg"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="Task"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:text="Today's , 14 Mar 2025"
                    android:textColor="#121417"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- Active Tasks -->
            <LinearLayout
                android:id="@+id/activeTasksContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include 
                    android:id="@+id/task1"
                    layout="@layout/item_planner_task" />
                <include 
                    android:id="@+id/task2"
                    layout="@layout/item_planner_task" />
                <include 
                    android:id="@+id/task3"
                    layout="@layout/item_planner_task" />
                <include 
                    android:id="@+id/task4"
                    layout="@layout/item_planner_task" />
                <include 
                    android:id="@+id/task5"
                    layout="@layout/item_planner_task" />

            </LinearLayout>

            <!-- Completed Section Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/task_badge_bg"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="Completed"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Completed Tasks -->
            <LinearLayout
                android:id="@+id/completedTasksContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include 
                    android:id="@+id/comp1"
                    layout="@layout/item_planner_task_completed" />
                <include 
                    android:id="@+id/comp2"
                    layout="@layout/item_planner_task_completed" />
                <include 
                    android:id="@+id/comp3"
                    layout="@layout/item_planner_task_completed" />
                <include 
                    android:id="@+id/comp4"
                    layout="@layout/item_planner_task_completed" />
                <include 
                    android:id="@+id/comp5"
                    layout="@layout/item_planner_task_completed" />
                <include 
                    android:id="@+id/comp6"
                    layout="@layout/item_planner_task_completed" />
                <include 
                    android:id="@+id/comp7"
                    layout="@layout/item_planner_task_completed" />

            </LinearLayout>

            <!-- Timeline Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="80dp">

                <!-- Timeline Item 1 -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    
                    <View
                        android:id="@+id/topDot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/profile_bg_circle"
                        android:backgroundTint="#121417" />
                    
                    <View
                        android:layout_width="2dp"
                        android:layout_height="40dp"
                        android:layout_below="@id/topDot"
                        android:layout_centerHorizontal="false"
                        android:layout_marginStart="3dp"
                        android:background="#DBE0E6" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/topDot"
                        android:layout_marginStart="16dp"
                        android:text="Completed \&quot;Complete design mockups\&quot;"
                        android:textColor="#000000"
                        android:textSize="16sp" />
                </RelativeLayout>

                <!-- Timeline Item 2 -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp">
                    
                    <View
                        android:id="@+id/bottomDot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/profile_bg_circle"
                        android:backgroundTint="#121417" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/bottomDot"
                        android:layout_marginStart="16dp"
                        android:text="Completed \&quot;Call with John at 2pm\&quot;"
                        android:textColor="#000000"
                        android:textSize="16sp" />
                </RelativeLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Create Button -->
    <LinearLayout
        android:id="@+id/btnCreateTask"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/bottomNavContainer"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/btn_dark_bg"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create +"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ===== BOTTOM NAVIGATION BAR ===== -->
    <RelativeLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_alignParentBottom="true">

        <LinearLayout
            android:id="@+id/bottomNavMenu"
            android:layout_width="340dp"
            android:layout_height="64dp"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="10dp"
            android:background="@drawable/bottom_nav_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:animateLayoutChanges="true"
            android:weightSum="5">

            <!-- Home -->
            <LinearLayout
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="0.8"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ivHome"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_home"
                    android:tint="#888888" />
                <TextView
                    android:id="@+id/tvHomeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Home"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Dashboard -->
            <LinearLayout
                android:id="@+id/navDashboard"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="0.8"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ivDashboard"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_carbon_dash"
                    android:tint="#888888" />
                <TextView
                    android:id="@+id/tvDashboardLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Dashboard"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Planner (Active) -->
            <LinearLayout
                android:id="@+id/navPlanner"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1.8"
                android:background="@drawable/active_tab_bg"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ivPlanner"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_task"
                    android:tint="#FFFFFF" />
                <TextView
                    android:id="@+id/tvPlannerLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Planner"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:visibility="visible" />
            </LinearLayout>

            <!-- Music -->
            <LinearLayout
                android:id="@+id/navMusic"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="0.8"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ivMusic"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_music"
                    android:tint="#888888" />
                <TextView
                    android:id="@+id/tvMusicLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Music"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- About -->
            <LinearLayout
                android:id="@+id/navAbout"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="0.8"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ivAbout"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_profile"
                    android:tint="#888888" />
                <TextView
                    android:id="@+id/tvAboutLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="About"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>

</RelativeLayout>
